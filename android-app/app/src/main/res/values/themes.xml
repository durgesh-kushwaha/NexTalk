<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NexTalk" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="Theme.NexTalk.IncomingCall" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/call_bg_dark</item>
        <item name="android:statusBarColor">@color/call_bg_dark</item>
        <item name="android:navigationBarColor">@color/call_bg_dark</item>
        <item name="android:windowShowWallpaper">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>
</resources>
