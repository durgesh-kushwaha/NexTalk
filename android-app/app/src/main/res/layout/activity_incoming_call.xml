<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/call_bg_dark"
    android:gravity="center_horizontal"
    android:keepScreenOn="true">

    <!-- Top section: Avatar + Caller info -->
    <LinearLayout
        android:id="@+id/callerInfoSection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="120dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/callerAvatar"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_caller_avatar"
            android:contentDescription="Caller avatar" />

        <TextView
            android:id="@+id/callerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Unknown Caller"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/callTypeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Incoming audio call"
            android:textColor="#B0B0B0"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Bottom section: Answer & Decline buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="80dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Decline button -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnDecline"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/btn_decline"
                android:contentDescription="Decline call"
                android:padding="18dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_call_decline" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Decline"
                android:textColor="#B0B0B0"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Answer button -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnAnswer"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/btn_answer"
                android:contentDescription="Answer call"
                android:padding="18dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_call_answer" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Answer"
                android:textColor="#B0B0B0"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
